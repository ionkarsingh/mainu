{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/debug",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/test",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/test-login",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/reset-password",
      "dest": "/backend/api/reset-password.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
